# Server
PORT=3000

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=GRA-db
DB_PASSWORD=your_db_password
DB_NAME=github_risk_analyzer

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

# GitHub API (optional but recommended to avoid rate limits)
GITHUB_TOKEN=ghp_your_personal_access_token

# Authentication (required — server will not start without this)
JWT_SECRET=change_this_to_a_long_random_secret

# Slack Alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Risk score threshold for Slack global alert (default: 60)
ALERT_SCORE_THRESHOLD=60

# Email Alerts via SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# CORS (optional, defaults to *)
ALLOWED_ORIGIN=http://localhost:3000

# Webhook signature secret (required for GitHub Webhook integration)
GITHUB_WEBHOOK_SECRET=your_webhook_secret
