# Server
PORT=3000

# Database → RDS 엔드포인트로 교체
DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_USER=GRA-db
DB_PASSWORD=your_db_password
DB_NAME=github_risk_analyzer

# Redis → ElastiCache 엔드포인트로 교체
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_URL=redis://your-elasticache-endpoint.cache.amazonaws.com:6379

# GitHub API
GITHUB_TOKEN=ghp_your_token

# Auth
JWT_SECRET=change_this_to_a_long_random_secret

# Slack (optional)
SLACK_WEBHOOK_URL=
ALERT_SCORE_THRESHOLD=60

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# CORS → EC2 퍼블릭 IP 또는 도메인으로 교체
ALLOWED_ORIGIN=http://your-ec2-public-ip:3000
